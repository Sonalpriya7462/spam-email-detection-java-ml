import weka.core.*;
import weka.classifiers.bayes.NaiveBayes;
import weka.classifiers.Classifier;
import weka.filters.*;
import weka.filters.unsupervised.attribute.StringToWordVector;

import java.io.BufferedReader;
import java.io.FileReader;

public class Main {

    public static void main(String[] args) throws Exception {

        // STEP 1: Load dataset (ARFF file)
        BufferedReader reader = new BufferedReader(
                new FileReader("data/spam.arff")
        );

        Instances data = new Instances(reader);
        data.setClassIndex(data.numAttributes() - 1);
        reader.close();

        // STEP 2: Convert text into word vectors (TF-IDF style)
        StringToWordVector filter = new StringToWordVector();
        filter.setInputFormat(data);

        Instances filteredData = Filter.useFilter(data, filter);

        // STEP 3: Train Naive Bayes model
        Classifier model = new NaiveBayes();
        model.buildClassifier(filteredData);

        // STEP 4: Test new email
        Instance test = new DenseInstance(2);
        test.setDataset(filteredData);

        test.setValue(0, "free money win lottery click now");

        double result = model.classifyInstance(test);

        // STEP 5: Output result
        System.out.println("Email Prediction: " +
                filteredData.classAttribute().value((int) result));
    }
}
